# Kopiér til .env og udfyld. I Dokploy sættes disse som Environment Variables.

# Adgangskode til PostgreSQL-databasen (vælg en stærk værdi).
POSTGRES_PASSWORD=skift-mig

# Kun nødvendig hvis du kører app'en uden docker-compose mod en ekstern database:
# DATABASE_URL=postgres://bruger:adgangskode@host:5432/skills
# DATABASE_SSL=true
